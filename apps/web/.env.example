# Base URL for API calls, baked into the bundle at BUILD time (this is a
# static site - there is no server to read an env var at runtime).
#
# Local dev (`npm run dev` / `npm run preview`): leave this as /api. The
# Vite dev server proxies /api to http://localhost:4000 (see vite.config.ts)
# so the browser never makes a cross-origin request.
#
# Production build (e.g. on Render): set this to the deployed API's full
# origin, e.g. VITE_API_URL=https://mansapay-api.onrender.com - set as a
# build-time environment variable on the Static Site service, not in this
# file. See DEPLOYMENT.md.
VITE_API_URL=/api
