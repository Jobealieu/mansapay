# --- apps/api ---
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://mansapay:mansapay@localhost:5433/mansapay
REDIS_URL=redis://localhost:6379
# generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-32-character-minimum-secret

# Africa's Talking sandbox credentials - create a sandbox app at
# https://account.africastalking.com to get these (username is "sandbox")
AT_API_KEY=change-me-sandbox-api-key
AT_USERNAME=sandbox

# AES-256-GCM key for encrypting Stellar wallet secret keys at rest.
# generate with: openssl rand -hex 32
WALLET_ENCRYPTION_KEY=change-me-to-a-64-character-hex-string-32-bytes

# DEV ONLY: when true, OTP codes are logged to the server console instead
# of being sent via Africa's Talking. Must be false for real users. In
# production this is only permitted when DEMO_MODE=true (see below) -
# otherwise the app refuses to start.
SMS_DEV_MODE=false

# Marks this deployment as the public academic grading demo. Its only
# effect is permitting SMS_DEV_MODE=true in production, so graders can
# complete signup while Africa's Talking is unavailable. Must never be
# set to true for a deployment serving real users.
DEMO_MODE=false

# Comma-separated list of origins allowed to call this API from a browser
# (CORS). Local dev: the Vite dev server's origin(s). Production: the
# deployed static site's URL (e.g. https://mansapay-web.onrender.com).
# Required - the app refuses to start without it. No trailing slashes.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- infra/docker-compose.yml (Postgres container) ---
POSTGRES_USER=mansapay
POSTGRES_PASSWORD=mansapay
POSTGRES_DB=mansapay
