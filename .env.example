# --- apps/api ---
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://mansapay:mansapay@localhost:5433/mansapay
REDIS_URL=redis://localhost:6379
# generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-32-character-minimum-secret

# Africa's Talking sandbox credentials - create a sandbox app at
# https://account.africastalking.com to get these (username is "sandbox")
AT_API_KEY=change-me-sandbox-api-key
AT_USERNAME=sandbox

# --- infra/docker-compose.yml (Postgres container) ---
POSTGRES_USER=mansapay
POSTGRES_PASSWORD=mansapay
POSTGRES_DB=mansapay
